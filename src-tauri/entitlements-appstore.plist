<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store 强制沙盒 -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- 允许读写用户主动选择过的文件（dialog / drag-drop 后书签化） -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- 应用级安全书签：用户选过的文件夹下次启动仍可访问 -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
    <!-- 允许直接写「下载」目录（输出模式 folder=Downloads 场景） -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- 不含 com.apple.security.network.* ：回归 tauri://localhost（local origin），IPC 经 __TAURI__ 注入，无需本地 HTTP 服务器。曾用 HTTP 服务器绕过 macOS 27 沙盒白屏，Tauri 2.11.5+ 已根治；network.server 反触发 App Store 自动分析驳回（2026-07） -->
</dict>
</plist>
