{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:window:allow-start-dragging",
    "default"
  ],
  "remote": {
    "urls": ["http://localhost", "http://127.0.0.1"]
  }
}
