{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Octor Compressor",
  "version": "2.0.0",
  "identifier": "com.octor.compressor",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Octor Compressor",
        "width": 760,
        "height": 680,
        "minWidth": 640,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#f8f6f8"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "macOS": {
      "frameworks": []
    }
  }
}